{
  "name": "jyothishyam-auth-scaffold",
  "version": "1.0.0",
  "description": "Express auth scaffold for Jyothishyam – EJS + vanilla CSS variant",
  "main": "server/app.js",
  "scripts": {
    "dev": "nodemon server/app.js",
    "start": "node server/app.js",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "build": "echo 'No build step required for Node server'"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "server/**/*.js"
    ]
  },
  "allowScripts": {
    "bcrypt@5.1.1": true
  }
}
