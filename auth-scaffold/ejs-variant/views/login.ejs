<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login — Jyothishyam</title>
  <meta name="description" content="Sign in to your Jyothishyam Vedic astrology account." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/tokens.css" />
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body class="auth-page">

  <%- include('partials/_loginBackground') %>

  <main class="auth-main" id="main-content" role="main">
    <div class="auth-card" role="region" aria-labelledby="page-title">

      <!-- Logo -->
      <div class="auth-logo" aria-hidden="true">🪐</div>

      <h1 class="auth-title" id="page-title">Login</h1>

      <!-- Global error / success -->
      <% if (error) { %>
        <div class="alert alert-error" role="alert" aria-live="polite"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success" role="alert" aria-live="polite"><%= success %></div>
      <% } %>

      <form method="POST" action="/login" class="auth-form" id="login-form" novalidate
            aria-label="Login form">

        <!-- Email -->
        <div class="field-group">
          <label for="email" class="field-label">Username</label>
          <div class="field-input-wrap" id="email-wrap">
            <span class="field-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            </span>
            <input
              type="email"
              id="email"
              name="email"
              class="field-input"
              placeholder="Type your email"
              value="<%= fields.email || '' %>"
              autocomplete="email"
              required
              aria-required="true"
              aria-describedby="email-error"
            />
          </div>
          <span class="field-error" id="email-error" role="alert" aria-live="polite"></span>
        </div>

        <!-- Password -->
        <div class="field-group">
          <label for="password" class="field-label">Password</label>
          <div class="field-input-wrap" id="password-wrap">
            <span class="field-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </span>
            <input
              type="password"
              id="password"
              name="password"
              class="field-input"
              placeholder="Type your password"
              autocomplete="current-password"
              required
              aria-required="true"
              aria-describedby="password-error"
            />
          </div>
          <span class="field-error" id="password-error" role="alert" aria-live="polite"></span>
        </div>

        <!-- Forgot password -->
        <div class="forgot-row">
          <a href="/forgot-password" class="forgot-link">Forgot password?</a>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn-primary" id="login-submit">
          <span class="btn-label">LOGIN</span>
          <span class="btn-spinner" hidden aria-hidden="true"></span>
        </button>

      </form>

      <!-- Social -->
      <div class="social-divider" aria-hidden="true"><span>Or Sign Up Using</span></div>

      <div class="social-buttons" role="group" aria-label="Social sign in (coming soon)">
        <!-- TODO: Wire up OAuth2 for each provider -->
        <button type="button" class="social-btn social-btn--fb"
                aria-label="Sign in with Facebook (coming soon)" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </button>
        <button type="button" class="social-btn social-btn--tw"
                aria-label="Sign in with Twitter (coming soon)" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true">
            <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53A4.48 4.48 0 0 0 16.34 3c-2.49 0-4.5 2.01-4.5 4.5 0 .35.04.7.11 1.02A12.78 12.78 0 0 1 3 4.89a4.48 4.48 0 0 0-.61 2.26c0 1.56.8 2.94 2 3.75a4.47 4.47 0 0 1-2.04-.56v.06c0 2.18 1.55 4 3.6 4.41a4.52 4.52 0 0 1-2.03.08 4.51 4.51 0 0 0 4.21 3.12A9.05 9.05 0 0 1 1 19.54a12.78 12.78 0 0 0 6.92 2.03c8.3 0 12.85-6.88 12.85-12.85 0-.2 0-.39-.01-.58A9.22 9.22 0 0 0 23 3z"/>
          </svg>
        </button>
        <button type="button" class="social-btn social-btn--ggl"
                aria-label="Sign in with Google (coming soon)" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
        </button>
      </div>

      <div class="auth-footer">
        <span>Or Sign Up Using</span>
        <a href="/register" class="auth-footer-link">SIGN UP</a>
      </div>

    </div>
  </main>

  <!-- Dark mode toggle -->
  <button class="dark-toggle" id="dark-toggle" aria-label="Toggle dark mode"
          aria-pressed="false" title="Toggle dark mode">🌙</button>

  <script src="/js/auth.js"></script>
</body>
</html>
